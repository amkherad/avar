{
  "manifest_version": 2,
  "name": "Avar Download Helper",
  "version": "0.1.0",
  "description": "Send media from web pages to the Avar download manager",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "webRequest",
    "downloads",
    "tabs",
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["media.js", "capture.js", "protocol.js", "hls.js", "context-menu.js", "download-intercept.js", "badge.js", "background.js"]
  },
  "browser_action": {
    "default_title": "Avar",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["media.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": ["page-response-hook.js", "media-hook.js"],
  "browser_specific_settings": {
    "gecko": {
      "id": "avar-download-helper@avar.io",
      "strict_min_version": "109.0"
    }
  }
}
