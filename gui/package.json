{
  "name": "avar-gui",
  "version": "0.1.0",
  "private": true,
  "description": "Avar Download Manager — web and desktop GUI",
  "homepage": "https://github.com/amkherad/avar",
  "author": {
    "name": "Ali Kherad",
    "email": "alimousavikherad@gmail.com"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite\" \"node scripts/wait-dev-server.cjs electron .\"",
    "dev:tiny": "concurrently -k \"vite\" \"node scripts/wait-dev-server.cjs node tiny/main.cjs\"",
    "prebuild": "python ../scripts/generate_version.py --root .. --out-env .avar-build.env",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "build:desktop": "npm run build && electron-builder --mac --win --linux",
    "build:desktop:current": "npm run build && electron-builder --dir",
    "start:tiny": "npm run build && concurrently -k \"vite preview --port 4173 --strictPort\" \"wait-on http://localhost:4173 && cross-env AVAR_GUI_URL=http://localhost:4173 node tiny/main.cjs\"",
    "build:tiny": "npm run build && node scripts/install-tinytron.cjs && node tiny/verify-build.cjs",
    "build:all": "python ../scripts/build_all.py",
    "icons": "node scripts/generate-icons.cjs"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "i18next": "^25.2.1",
    "mermaid": "^11.15.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^15.5.2",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/react-i18next": "^7.8.3",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "node-gyp": "^10.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "io.avar.gui",
    "productName": "Avar",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "protocols": [
      {
        "name": "Avar",
        "schemes": ["avar"]
      }
    ],
    "linux": {
      "maintainer": "Ali Kherad <alimousavikherad@gmail.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
