{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 1,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "ninja",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "inherits": "ninja",
      "binaryDir": "${sourceDir}/output/cmake-build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "ninja",
      "binaryDir": "${sourceDir}/output/cmake-build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "build",
      "displayName": "Build (Release)",
      "inherits": "ninja",
      "binaryDir": "${sourceDir}/output/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "coverage",
      "displayName": "Coverage",
      "inherits": "ninja",
      "binaryDir": "${sourceDir}/output/build-coverage",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "AVAR_ENABLE_COVERAGE": "ON"
      }
    },
    {
      "name": "gui",
      "displayName": "Embedded GUI",
      "inherits": "ninja",
      "binaryDir": "${sourceDir}/output/build-gui",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AVAR_BUILD_GUI": "ON"
      }
    },
    {
      "name": "all",
      "displayName": "All-in-one",
      "inherits": "ninja",
      "binaryDir": "${sourceDir}/output/build-all",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AVAR_BUILD_ALL": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "build",
      "configurePreset": "build"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "gui",
      "configurePreset": "gui",
      "targets": ["avar-gui"]
    },
    {
      "name": "all",
      "configurePreset": "all",
      "targets": ["avar"]
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
